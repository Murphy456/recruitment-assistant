{
  "manifest_version": 3,
  "name": "招聘助手",
  "version": "1.0.0",
  "description": "智能筛选候选人，自动打招呼获取简历",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.zhaopin.com/*",
    "https://*.zhipin.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zhaopin.com/*"],
      "js": ["src/content/index.js"],
      "css": ["assets/content-BjfUzBVQ.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://*.zhaopin.com/*", "https://*.zhipin.com/*"]
    }
  ]
}
