{
  "manifest_version": 3,
  "name": "招聘助手",
  "version": "1.0.0",
  "description": "智能筛选候选人，自动打招呼获取简历",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://*.zhaopin.com/*",
    "https://*.zhipin.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-DAER7wu3.js"
      ],
      "matches": [
        "https://*.zhaopin.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/index-DojqXMZB.css"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "options_page": "src/options/index.html",
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.zhaopin.com/*"
      ],
      "resources": [
        "assets/settings-CAV-tMK1.js",
        "assets/index.tsx-pp-3HkPc.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
